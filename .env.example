# Copy to .env and fill in your values
# Never commit .env to git

# OpenAI
OPENAI_API_KEY=sk-...

# LangSmith — get your key at https://smith.langchain.com
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=enterprise-rag-agent

# Qdrant (run locally: docker run -p 6333:6333 qdrant/qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=enterprise_kb

# OpenAI model (gpt-4o-mini is cheaper for evals, gpt-4o for production)
OPENAI_MODEL=gpt-4o-mini

# Optional: Confluence integration
# CONFLUENCE_URL=https://yourcompany.atlassian.net
# CONFLUENCE_USERNAME=your@email.com
# CONFLUENCE_API_KEY=...
